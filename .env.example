# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WA_FROM=whatsapp:+14155238886
TWILIO_WA_TO=whatsapp:+50700000000

# Instagram API (Graph API)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# Facebook Page API
FACEBOOK_ACCESS_TOKEN=your_page_access_token
FACEBOOK_PAGE_ID=your_page_id

# Twitter/X API v2
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Metricool (Recommended - posts to all platforms)
METRICOOL_TOKEN=your_metricool_api_token
METRICOOL_USER_ID=your_metricool_user_id

# Legacy (deprecated, use above instead)
# INSTAGRAM_USERNAME=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password

# AI Services (optional but recommended)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Content Creator Settings
CREATOR_PERSONA=tiktok_strategist  # tiktok_strategist | growth_hacker | content_creator
GENERATE_INTERVAL=3600
CONTENT_LANGUAGE=es  # es | en

# Bot Settings
APPROVAL_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
DEFAULT_PLATFORMS=instagram,facebook,twitter,tiktok

# Backup Settings
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
